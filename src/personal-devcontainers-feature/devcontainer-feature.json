{
  "id": "personal-devcontainers-feature",
  "version": "1.1.0",
  "name": "Personal devcontainers feature",
  "mounts": [
    {
      "source": "${localEnv:HOME}/.claude",
      "target": "/mnt/personal-devcontainers-feature/.claude",
      "type": "bind"
    },
    {
      "source": "${localEnv:HOME}/.codex",
      "target": "/mnt/personal-devcontainers-feature/.codex",
      "type": "bind"
    }
  ],
  "postCreateCommand": "/usr/local/share/personal-devcontainers-feature/bootstrap.sh"
}
